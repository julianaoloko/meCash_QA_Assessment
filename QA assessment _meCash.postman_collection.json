  "item": [
    {
      "name": "Successful_transfer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Transfer status is SUCCESS\", function () {\r",
              "    pm.expect(response.status).to.eql(\"SUCCESS\");\r",
              "});\r",
              "\r",
              "pm.test(\"Transaction ID exists\", function () {\r",
              "    pm.expect(response.transactionId).to.not.be.null;\r",
              "});\r",
              "\r",
              "pm.test(\"Amount is correct\", function () {\r",
              "    pm.expect(response.amount).to.eql(500);\r",
              "});\r",
              "\r",
              "pm.test(\"Currency is GBP\", function () {\r",
              "    pm.expect(response.currency).to.eql(\"GBP\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "fb2d1320",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"senderWalletId\": \"WALLET001\",\r\n  \"receiverWalletId\": \"WALLET002\",\r\n  \"amount\": 500,\r\n  \"currency\": \"GBP\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://my.api.mockaroo.com/apiv1/transfers",
          "protocol": "https",
          "host": [
            "my",
            "api",
            "mockaroo",
            "com"
          ],
          "path": [
            "apiv1",
            "transfers"
          ]
        }
      },
      "response": []
    },
